# OCI Enterprise AI endpoint configuration
OCI_REGION=eu-frankfurt-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..example
OCI_PROJECT_ID=ocid1.generativeaiproject.oc1..example

# Model and retrieval configuration
OCI_MODEL_ID=example-model-id
OCI_VECTOR_STORE_ID=example-vector-store-id

# Runtime tuning
FILE_SEARCH_MAX_NUM_RESULTS=10
RESPONSES_TIMEOUT_SECONDS=60
STREAM_FINALIZATION_MODE=never

# Voice request intake. Enabled by default; current implementation accepts
# audio uploads and transcribes them through OCI Speech.
SPEECH_TO_TEXT_ENABLED=true
AUDIO_UPLOAD_MAX_SIZE_MB=25
OCI_SPEECH_MODEL=whisper-medium
OCI_SPEECH_LANGUAGE_CODE=auto
OCI_SPEECH_STAGING_NAMESPACE=replace-with-object-storage-namespace
OCI_SPEECH_STAGING_BUCKET=replace-with-speech-staging-bucket
OCI_SPEECH_INPUT_PREFIX=speech-input
OCI_SPEECH_OUTPUT_PREFIX=speech-output
AUDIO_TRANSCRIPTION_TIMEOUT_SECONDS=120
AUDIO_TRANSCRIPTION_POLL_INTERVAL_SECONDS=2
OCI_SPEECH_WHISPER_PROMPT=

# Optional Langfuse observability. Disabled unless explicitly enabled.
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# OpenAI-compatible authentication for OCI Enterprise AI
# Local Docker Compose deployments can also use OCI config-file authentication
# by mounting ${HOME}/.oci into the backend container through docker-compose.yml
# and setting:
# OCI_AUTH_MODE=config_file
# OCI_CONFIG_FILE=/Users/your-user/.oci/config
# OCI_PROFILE=DEFAULT
OPENAI_API_KEY=replace-with-your-api-key

# Optional agent-managed connector ingestion. Requires OCI_AUTH_MODE to be
# resource_principal in hosted deployments or config_file in local Docker
# Compose deployments.
DOCUMENT_INGESTION_ENABLED=false
OCI_DOCUMENT_NAMESPACE=replace-with-object-storage-namespace
OCI_DOCUMENT_BUCKET=replace-with-object-storage-bucket
OCI_VECTOR_STORE_CONNECTOR_ID=replace-with-vector-store-connector-id
DOCUMENT_INGESTION_DEFAULT_PREFIX=
DOCUMENT_INGESTION_MAX_FILES=10
DOCUMENT_INGESTION_MAX_FILE_SIZE_MB=25

# Optional IDCS authentication for protected Hosted Applications.
# Used by the Python CLI client to request an OAuth access token.
IDENTITY_DOMAIN_URL=https://idcs-example.identity.oraclecloud.com
CONFIDENTIAL_APPLICATION_ID=replace-with-confidential-application-id
CONFIDENTIAL_APPLICATION_SECRET=replace-with-confidential-application-secret
# OAuth token request scope. For IDCS Hosted Application auth, this is commonly
# the primary audience concatenated with the scope claim, for example:
# audience=hello_world, scope=invoke -> IDCS_SCOPE=hello_worldinvoke
IDCS_SCOPE=replace-with-primary-audience-plus-scope
