# OCI Enterprise AI endpoint configuration
OCI_REGION=eu-frankfurt-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..example
OCI_PROJECT_ID=ocid1.generativeaiproject.oc1..example

# Model and retrieval configuration
OCI_MODEL_ID=example-model-id
OCI_VECTOR_STORE_ID=example-vector-store-id

# Runtime tuning
FILE_SEARCH_MAX_NUM_RESULTS=10
RESPONSES_TIMEOUT_SECONDS=60

# OpenAI-compatible authentication for OCI Enterprise AI
OPENAI_API_KEY=replace-with-your-api-key
